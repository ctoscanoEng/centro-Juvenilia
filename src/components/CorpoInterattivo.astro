---
/*
  Sezione "Percorso di recupero interattivo": corpo 3D + pannello suggerimenti.
  Three.js viene importato SOLO quando la sezione entra nel viewport.
  Fallback accessibile: gli stessi pulsanti-zona funzionano senza WebGL/mouse.
*/
import { ZONE, trattamentiPerZona, professionistiPerZona } from '../data/zone';

const zoneJson = JSON.stringify(
  Object.fromEntries(
    ZONE.map((z) => [
      z.id,
      {
        nome: z.nome,
        descrizione: z.descrizione,
        trattamenti: trattamentiPerZona(z.id).map((t) => ({ slug: t.slug, nome: t.nome })),
        professionisti: professionistiPerZona(z.id).map((p) => ({ slug: p.slug, nome: p.nome, ruolo: p.ruolo })),
      },
    ]),
  ),
);
---

<section id="percorso-recupero" class="bg-teal-50 py-20" aria-labelledby="corpo-titolo">
  <div class="mx-auto max-w-6xl px-5">
    <p class="text-sm font-semibold uppercase tracking-wider text-coral-600" data-reveal>
      Percorso di recupero interattivo
    </p>
    <h2 id="corpo-titolo" class="mt-2 font-display text-3xl font-semibold text-teal-900 md:text-5xl" data-reveal>
      Dove ti fa male?
    </h2>
    <p class="mt-4 max-w-2xl text-ink/70" data-reveal>
      Tocca una zona del corpo: ti mostriamo i trattamenti più indicati e il professionista giusto
      del nostro team. <strong>Non è una diagnosi</strong> — è il primo passo per orientarti.
    </p>

    <div class="mt-10 grid items-start gap-8 lg:grid-cols-2">
      <div>
        <div
          id="body3d-container"
          class="relative mx-auto aspect-[3/4] w-full max-w-md rounded-3xl bg-gradient-to-b from-white to-teal-100 shadow-inner"
          data-zone={zoneJson}
        >
          <p id="body3d-hint" class="pointer-events-none absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full bg-teal-900/80 px-4 py-1 text-xs text-paper">
            Trascina per ruotare · tocca una zona
          </p>
        </div>

        <fieldset class="mt-6">
          <legend class="text-sm font-medium text-ink/60">Oppure scegli la zona da qui:</legend>
          <div class="mt-3 flex flex-wrap gap-2" id="zone-buttons" role="group">
            {
              ZONE.map((z) => (
                <button
                  type="button"
                  data-zona={z.id}
                  class="rounded-full border border-teal-300 bg-white px-4 py-1.5 text-sm text-teal-900 transition-colors hover:bg-teal-700 hover:text-paper aria-pressed:bg-coral-500 aria-pressed:border-coral-500 aria-pressed:text-paper"
                  aria-pressed="false"
                >
                  {z.nome}
                </button>
              ))
            }
          </div>
        </fieldset>
      </div>

      <div
        id="zona-panel"
        class="rounded-3xl border border-teal-900/10 bg-white p-8 shadow-sm lg:sticky lg:top-24"
        aria-live="polite"
      >
        <p class="text-ink/50">
          Seleziona una zona del corpo per vedere i trattamenti consigliati e chi, nel team, se ne
          occupa ogni giorno.
        </p>
      </div>
    </div>

    <p class="mt-8 text-xs text-ink/50">
      ⚕️ Questo strumento fornisce un orientamento generale e non sostituisce in alcun modo una
      valutazione clinica professionale né il parere del medico.
    </p>
  </div>
</section>

<script>
  const container = document.getElementById('body3d-container')!;
  const panel = document.getElementById('zona-panel')!;
  const buttons = [...document.querySelectorAll<HTMLButtonElement>('#zone-buttons [data-zona]')];
  const zone = JSON.parse(container.dataset.zone!) as Record<
    string,
    {
      nome: string;
      descrizione: string;
      trattamenti: { slug: string; nome: string }[];
      professionisti: { slug: string; nome: string; ruolo: string }[];
    }
  >;

  let handle: { select(z: string | null): void } | null = null;

  function render(zonaId: string) {
    const z = zone[zonaId];
    if (!z) return;
    buttons.forEach((b) => b.setAttribute('aria-pressed', String(b.dataset.zona === zonaId)));
    handle?.select(zonaId);
    panel.innerHTML = `
      <h3 class="font-display text-2xl font-semibold text-teal-900">${z.nome}</h3>
      <p class="mt-1 text-sm text-ink/60">${z.descrizione}</p>
      <h4 class="mt-6 text-sm font-semibold uppercase tracking-wider text-coral-600">Trattamenti indicati</h4>
      <ul class="mt-2 space-y-2">
        ${z.trattamenti
          .map(
            (t) =>
              `<li><a class="font-medium text-teal-700 underline-offset-4 hover:underline" href="/trattamenti/${t.slug}">${t.nome}</a></li>`,
          )
          .join('')}
      </ul>
      <h4 class="mt-6 text-sm font-semibold uppercase tracking-wider text-coral-600">A chi rivolgerti</h4>
      <ul class="mt-2 space-y-1">
        ${z.professionisti
          .map((p) => `<li class="text-sm"><span class="font-semibold">${p.nome}</span> — ${p.ruolo}</li>`)
          .join('')}
      </ul>
      <a href="/contatti#prenota" data-magnetic class="mt-8 inline-block rounded-full bg-coral-500 px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-coral-600">
        Prenota una valutazione
      </a>`;
  }

  buttons.forEach((b) => b.addEventListener('click', () => render(b.dataset.zona!)));
  container.addEventListener('zona-selezionata', (e) =>
    render((e as CustomEvent<{ zonaId: string }>).detail.zonaId),
  );

  // Three.js solo quando serve, e solo se il contesto lo consente
  const supportsWebGL = (() => {
    try {
      return !!document.createElement('canvas').getContext('webgl2');
    } catch {
      return false;
    }
  })();

  if (supportsWebGL) {
    const io = new IntersectionObserver(
      async ([entry]) => {
        if (!entry.isIntersecting) return;
        io.disconnect();
        const { mountBody3D } = await import('../lib/body3d');
        handle = mountBody3D(container);
      },
      { rootMargin: '200px' },
    );
    io.observe(container);
  } else {
    document.getElementById('body3d-hint')?.remove();
    container.classList.add('hidden');
  }
</script>
