---
const nav = [
  { href: '/chi-siamo', label: 'Chi siamo' },
  { href: '/trattamenti', label: 'Trattamenti' },
  { href: '/juvenilia-lab', label: 'Juvenilia Lab' },
  { href: '/tecnologie', label: 'Tecnologie' },
  { href: '/testimonianze', label: 'Testimonianze' },
  { href: '/contatti', label: 'Contatti' },
];
const current = Astro.url.pathname;
---

<header class="fixed inset-x-0 top-0 z-50 backdrop-blur-md bg-paper/80 border-b border-teal-900/5">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
    <a href="/" class="font-display text-xl font-semibold tracking-tight text-teal-900" aria-label="Studio Juvenilia — Home">
      Studio<span class="text-coral-500">Juvenilia</span>
    </a>

    <nav aria-label="Navigazione principale" class="hidden items-center gap-6 lg:flex">
      {
        nav.map(({ href, label }) => (
          <a
            href={href}
            aria-current={current.startsWith(href) ? 'page' : undefined}
            class:list={[
              'text-sm font-medium transition-colors hover:text-coral-500',
              current.startsWith(href) ? 'text-coral-600' : 'text-ink/80',
            ]}
          >
            {label}
          </a>
        ))
      }
      <a
        href="/contatti#prenota"
        data-magnetic
        class="inline-block rounded-full bg-teal-700 px-5 py-2 text-sm font-semibold text-paper transition-colors hover:bg-teal-900"
      >
        Prenota una valutazione
      </a>
    </nav>

    <button
      id="nav-toggle"
      class="lg:hidden rounded-md p-2 text-teal-900"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Apri il menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>

  <nav id="mobile-nav" aria-label="Navigazione mobile" class="hidden border-t border-teal-900/10 bg-paper px-5 py-4 lg:hidden">
    <ul class="flex flex-col gap-3">
      {
        nav.map(({ href, label }) => (
          <li>
            <a href={href} class="block py-1 text-base font-medium text-ink/90">
              {label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="/contatti#prenota" class="mt-2 inline-block rounded-full bg-teal-700 px-5 py-2 text-sm font-semibold text-paper">
          Prenota una valutazione
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Chiudi il menu' : 'Apri il menu');
  });
</script>
