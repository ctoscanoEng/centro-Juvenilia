---
/*
  Scroll-telling: il percorso del paziente in 5 tappe.
  Sezione pinnata con GSAP ScrollTrigger; con reduced-motion diventa
  una semplice lista verticale (nessun pin).
*/
const tappe = [
  {
    n: '01',
    titolo: 'Il dolore',
    testo: 'Arrivi con un problema: un infortunio, un dolore che non passa, una ricaduta. Ti ascoltiamo prima di toccare qualsiasi macchinario.',
    icona: 'M12 21c-4-4-8-7.5-8-11.5a5 5 0 0 1 8-4 5 5 0 0 1 8 4c0 4-4 7.5-8 11.5z',
  },
  {
    n: '02',
    titolo: 'La valutazione',
    testo: 'Test funzionali, analisi posturale, misurazioni oggettive. Capiamo la causa, non solo il sintomo, e definiamo insieme gli obiettivi.',
    icona: 'M9 3h6l1 4h4l-2 5 2 5h-4l-1 4H9l-1-4H4l2-5-2-5h4z',
  },
  {
    n: '03',
    titolo: 'Il trattamento',
    testo: 'Terapia manuale, esercizio terapeutico e tecnologie strumentali, combinati in un piano che si adatta ai tuoi progressi reali.',
    icona: 'M8 12h8M12 8v8M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z',
  },
  {
    n: '04',
    titolo: 'Juvenilia Lab',
    testo: 'Riatletizzazione, test isocinetici e prevenzione: il nostro laboratorio ti riporta in condizione — più forte di prima.',
    icona: 'M6 20V10m6 10V4m6 16v-7',
  },
  {
    n: '05',
    titolo: 'Il ritorno',
    testo: 'Torni a correre, giocare, vivere. E con i criteri oggettivi di ritorno allo sport, riduci il rischio di farti male di nuovo.',
    icona: 'M13 5l7 7-7 7M4 12h16',
  },
];
---

<section id="percorso" class="bg-paper py-20" aria-labelledby="percorso-titolo">
  <div class="mx-auto max-w-6xl px-5">
    <p class="text-sm font-semibold uppercase tracking-wider text-coral-600" data-reveal>Come lavoriamo</p>
    <h2 id="percorso-titolo" class="mt-2 font-display text-3xl font-semibold text-teal-900 md:text-5xl" data-reveal>
      Il tuo percorso, tappa per tappa
    </h2>
  </div>

  <div id="percorso-track" class="mx-auto mt-12 max-w-6xl px-5">
    <ol id="percorso-list" class="flex flex-col gap-6 lg:flex-row lg:gap-5">
      {
        tappe.map((t) => (
          <li
            class="percorso-card min-w-0 flex-1 rounded-3xl border border-teal-900/10 bg-white p-7 shadow-sm"
            data-reveal
          >
            <div class="flex items-center justify-between">
              <span class="font-display text-4xl font-semibold text-teal-100">{t.n}</span>
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#f46f4d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={t.icona} />
              </svg>
            </div>
            <h3 class="mt-4 font-display text-xl font-semibold text-teal-900">{t.titolo}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/70">{t.testo}</p>
          </li>
        ))
      }
    </ol>
    <div class="mt-8 h-1.5 overflow-hidden rounded-full bg-teal-100" aria-hidden="true">
      <div id="percorso-progress" class="h-full w-0 rounded-full bg-coral-500"></div>
    </div>
  </div>
</section>

<script>
  import { gsap, prefersReducedMotion } from '../lib/motion';

  if (!prefersReducedMotion() && matchMedia('(min-width: 1024px)').matches) {
    const cards = gsap.utils.toArray<HTMLElement>('.percorso-card');
    gsap.fromTo(
      cards,
      { y: 60, autoAlpha: 0.2 },
      {
        y: 0,
        autoAlpha: 1,
        stagger: 0.15,
        ease: 'none',
        scrollTrigger: { trigger: '#percorso-track', start: 'top 75%', end: 'top 20%', scrub: true },
      },
    );
    gsap.to('#percorso-progress', {
      width: '100%',
      ease: 'none',
      scrollTrigger: { trigger: '#percorso-track', start: 'top 75%', end: 'bottom 40%', scrub: true },
    });
  }
</script>
