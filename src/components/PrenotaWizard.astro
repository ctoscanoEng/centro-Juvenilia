---
/*
  Prenotazione WhatsApp-first.
  Il paziente compone la richiesta (motivo, professionista, preferenze orarie),
  vede in anteprima il messaggio già scritto e lo invia con un tap al numero
  unico prenotazioni. La segreteria risponde su WhatsApp per confermare
  giorno e ora: nessun account, nessun backend, nessun dato salvato dal sito.

  Se il corpo interattivo passa ?zona=<id>, il motivo viene pre-compilato.
*/
import { STUDIO } from '../data/studio';
import { TEAM } from '../data/team';
import { ZONE } from '../data/zone';

const waNumber = STUDIO.whatsapp.replace(/[\s+]/g, '');
const telHref = `tel:${STUDIO.telefono.replace(/\s/g, '')}`;

const MOTIVI = [
  'Prima valutazione',
  'Fisioterapia',
  'Osteopatia',
  'Ozonoterapia',
  'Riabilitazione sportiva',
  'Altro',
];

const GIORNI = ['Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab'];
const FASCE = ['Indifferente', 'Mattina', 'Pomeriggio'];

const zoneNomi = JSON.stringify(Object.fromEntries(ZONE.map((z) => [z.id, z.nome])));

const chip =
  'cursor-pointer select-none rounded-full border border-teal-900/20 bg-paper px-4 py-1.5 text-sm text-ink/80 transition-colors peer-checked:border-teal-700 peer-checked:bg-teal-700 peer-checked:text-paper hover:border-teal-700';
---

<div
  id="prenota"
  class="scroll-mt-24 rounded-3xl border border-teal-900/10 bg-white p-7 shadow-sm"
  data-wa-number={waNumber}
  data-zone-nomi={zoneNomi}
  data-reveal
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="font-display text-xl font-semibold text-teal-900">Prenota in 30 secondi</h2>
      <p class="mt-1 text-sm text-ink/70">
        Componi la richiesta qui sotto: parte come messaggio WhatsApp <strong>dal tuo telefono</strong> e
        la nostra segreteria ti risponde per confermare giorno e ora.
      </p>
    </div>
    <span class="hidden shrink-0 rounded-full bg-[#25D366]/10 p-2.5 text-[#25D366] sm:block" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.3A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.2-1.1l-.3-.2-3.1.8.8-3-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.1-.7l.4-.5c.1-.2.1-.3.2-.5v-.5C10.2 9.2 9.7 8 9.5 7.5c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.5.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2l-.5-.3Z"/></svg>
    </span>
  </div>

  <form id="wizard" class="mt-6 space-y-6">
    <!-- 1 · Motivo -->
    <fieldset>
      <legend class="text-sm font-semibold text-teal-900">
        <span class="mr-1.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-teal-50 text-xs font-bold text-teal-700">1</span>
        Di cosa hai bisogno?
      </legend>
      <div class="mt-3 flex flex-wrap gap-2">
        {
          MOTIVI.map((m, i) => (
            <label>
              <input type="radio" name="motivo" value={m} checked={i === 0} class="peer sr-only" />
              <span class={chip}>{m}</span>
            </label>
          ))
        }
      </div>
      <p id="zona-badge" class="mt-3 hidden items-center gap-2 text-sm text-coral-700">
        <span>Zona indicata sul corpo interattivo: <strong id="zona-badge-nome"></strong></span>
        <button type="button" id="zona-badge-x" class="rounded-full border border-coral-700/30 px-2 text-xs hover:bg-coral-500 hover:text-white" aria-label="Rimuovi la zona dalla richiesta">✕</button>
      </p>
    </fieldset>

    <!-- 2 · Professionista -->
    <fieldset>
      <legend class="text-sm font-semibold text-teal-900">
        <span class="mr-1.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-teal-50 text-xs font-bold text-teal-700">2</span>
        Con chi vuoi essere seguito?
      </legend>
      <div class="mt-3 grid gap-2 sm:grid-cols-2">
        <label>
          <input type="radio" name="professionista" value="Primo disponibile" checked class="peer sr-only" />
          <span class="flex h-full cursor-pointer items-center gap-3 rounded-2xl border border-teal-900/20 bg-paper p-3 transition-colors peer-checked:border-teal-700 peer-checked:bg-teal-50 hover:border-teal-700">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal-700 font-semibold text-paper" aria-hidden="true">✦</span>
            <span>
              <span class="block text-sm font-semibold text-teal-900">Primo disponibile</span>
              <span class="block text-xs text-ink/70">Consigliatemi voi, mi fido</span>
            </span>
          </span>
        </label>
        {
          TEAM.map((p) => (
            <label>
              <input type="radio" name="professionista" value={p.nome} class="peer sr-only" />
              <span class="flex h-full cursor-pointer items-center gap-3 rounded-2xl border border-teal-900/20 bg-paper p-3 transition-colors peer-checked:border-teal-700 peer-checked:bg-teal-50 hover:border-teal-700">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-coral-500 font-semibold text-white" aria-hidden="true">
                  {p.nome.replace('Dott. ', '').split(' ').map((n) => n[0]).join('')}
                </span>
                <span>
                  <span class="block text-sm font-semibold text-teal-900">{p.nome}</span>
                  <span class="block text-xs text-ink/70">{p.ruolo}</span>
                </span>
              </span>
            </label>
          ))
        }
      </div>
    </fieldset>

    <!-- 3 · Preferenze orarie -->
    <fieldset>
      <legend class="text-sm font-semibold text-teal-900">
        <span class="mr-1.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-teal-50 text-xs font-bold text-teal-700">3</span>
        Quando ti è più comodo? <span class="font-normal text-ink/60">(facoltativo)</span>
      </legend>
      <div class="mt-3 flex flex-wrap gap-2" role="group" aria-label="Giorni preferiti">
        {
          GIORNI.map((g) => (
            <label>
              <input type="checkbox" name="giorni" value={g} class="peer sr-only" />
              <span class={chip}>{g}</span>
            </label>
          ))
        }
      </div>
      <div class="mt-2 flex flex-wrap gap-2" role="group" aria-label="Fascia oraria">
        {
          FASCE.map((f, i) => (
            <label>
              <input type="radio" name="fascia" value={f} checked={i === 0} class="peer sr-only" />
              <span class={chip}>{f}</span>
            </label>
          ))
        }
      </div>
    </fieldset>

    <!-- 4 · Chi sei -->
    <fieldset>
      <legend class="text-sm font-semibold text-teal-900">
        <span class="mr-1.5 inline-flex h-5 w-5 items-center justify-center rounded-full bg-teal-50 text-xs font-bold text-teal-700">4</span>
        Come ti chiami?
      </legend>
      <input
        name="nome"
        placeholder="Nome e cognome"
        autocomplete="name"
        class="mt-3 w-full rounded-xl border border-teal-900/20 bg-paper px-4 py-2.5 text-sm"
      />
      <textarea
        name="note"
        rows="2"
        placeholder="Note per la segreteria (facoltative)"
        class="mt-2 w-full rounded-xl border border-teal-900/20 bg-paper px-4 py-2.5 text-sm"
      ></textarea>
      <p class="mt-1.5 text-xs text-ink/60">
        Suggerimento: i dettagli sul tuo stato di salute raccontali di persona, non nel messaggio.
      </p>
    </fieldset>
  </form>

  <!-- Anteprima messaggio -->
  <div class="mt-6 rounded-2xl bg-[#e7f6ee] p-4">
    <p class="text-xs font-semibold uppercase tracking-wider text-ink/50">Anteprima del messaggio</p>
    <div class="mt-2 max-w-md rounded-2xl rounded-tl-sm bg-white p-4 shadow-sm">
      <p id="wa-preview" class="whitespace-pre-line text-sm leading-relaxed text-ink/90"></p>
      <p class="mt-2 text-right text-[10px] text-ink/40">ora ✓✓</p>
    </div>
  </div>

  <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
    <a
      id="wa-cta"
      href="#"
      rel="noopener"
      target="_blank"
      data-magnetic
      class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-7 py-3 font-semibold text-white shadow-sm transition-transform hover:brightness-95"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.7 14.9L2 22l5.3-1.3A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.2-1.1l-.3-.2-3.1.8.8-3-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.6-6.1c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.6.8-.8 1-.1.2-.3.2-.5.1a6.7 6.7 0 0 1-3.4-3c-.3-.4 0-.5.1-.7l.4-.5c.1-.2.1-.3.2-.5v-.5C10.2 9.2 9.7 8 9.5 7.5c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.5.6.2 1.2.2 1.6.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.1-1.2l-.5-.3Z"/></svg>
      Invia la richiesta su WhatsApp
    </a>
    <button
      type="button"
      id="wa-copy"
      class="rounded-full border border-teal-900/20 px-6 py-3 text-sm font-medium text-ink/80 transition-colors hover:border-teal-700 hover:text-teal-900"
    >
      Copia il messaggio
    </button>
  </div>

  <p class="mt-4 text-xs leading-relaxed text-ink/60">
    Ti risponderemo per confermare l'appuntamento negli orari di apertura
    ({STUDIO.orari[0].giorni.toLowerCase()} {STUDIO.orari[0].ore}, sabato mattina).
    Preferisci parlare a voce? <a href={telHref} class="font-medium text-teal-700 underline underline-offset-2 hover:text-coral-700">Chiama lo {STUDIO.telefono}</a>.
  </p>
</div>

<script>
  const root = document.getElementById('prenota')!;
  const form = document.getElementById('wizard') as HTMLFormElement;
  const preview = document.getElementById('wa-preview')!;
  const cta = document.getElementById('wa-cta') as HTMLAnchorElement;
  const copyBtn = document.getElementById('wa-copy') as HTMLButtonElement;
  const waNumber = root.dataset.waNumber!;
  const zoneNomi = JSON.parse(root.dataset.zoneNomi!) as Record<string, string>;

  // Zona pre-selezionata dal corpo interattivo (?zona=ginocchio)
  let zonaNome: string | null = zoneNomi[new URLSearchParams(location.search).get('zona') ?? ''] ?? null;
  const badge = document.getElementById('zona-badge')!;
  const badgeNome = document.getElementById('zona-badge-nome')!;
  if (zonaNome) {
    badge.classList.remove('hidden');
    badge.classList.add('flex');
    badgeNome.textContent = zonaNome;
  }
  document.getElementById('zona-badge-x')!.addEventListener('click', () => {
    zonaNome = null;
    badge.remove();
    aggiorna();
  });

  function messaggio(): string {
    const d = new FormData(form);
    const motivo = String(d.get('motivo'));
    const prof = String(d.get('professionista'));
    const giorni = d.getAll('giorni').join('/');
    const fascia = String(d.get('fascia'));
    const nome = String(d.get('nome') ?? '').trim();
    const note = String(d.get('note') ?? '').trim();

    const righe = [
      'Ciao! Vorrei prenotare un appuntamento allo Studio Juvenilia.',
      '',
      `📋 Motivo: ${motivo}${zonaNome ? ` — zona ${zonaNome.toLowerCase()}` : ''}`,
      `👤 Professionista: ${prof}`,
    ];
    if (giorni || fascia !== 'Indifferente') {
      const pref = [giorni, fascia !== 'Indifferente' ? fascia.toLowerCase() : '']
        .filter(Boolean)
        .join(', ');
      righe.push(`📅 Preferenza: ${pref}`);
    }
    if (nome) righe.push(`🙋 Nome: ${nome}`);
    if (note) righe.push(`📝 Note: ${note}`);
    righe.push('', 'Grazie! (richiesta inviata dal sito)');
    return righe.join('\n');
  }

  function aggiorna() {
    const msg = messaggio();
    preview.textContent = msg;
    cta.href = `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`;
  }

  form.addEventListener('input', aggiorna);
  aggiorna();

  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(messaggio());
      copyBtn.textContent = '✓ Copiato!';
    } catch {
      copyBtn.textContent = 'Copia non riuscita';
    }
    setTimeout(() => (copyBtn.textContent = 'Copia il messaggio'), 2000);
  });
</script>
