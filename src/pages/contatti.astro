---
import Base from '../layouts/Base.astro';
import PrenotaWizard from '../components/PrenotaWizard.astro';
import { STUDIO } from '../data/studio';

const telHref = `tel:${STUDIO.telefono.replace(/\s/g, '')}`;
const waHref = `https://wa.me/${STUDIO.whatsapp.replace(/[\s+]/g, '')}?text=${encodeURIComponent('Ciao! Vorrei informazioni su una visita allo Studio Juvenilia.')}`;
---

<Base
  title="Contatti e prenotazioni | Studio Juvenilia — Via Giotto 28, Caserta"
  description="Contatta lo Studio Juvenilia a Caserta: telefono, WhatsApp, mappa e modulo di prenotazione. Via Giotto 28, 81100 Caserta. Prenota la tua valutazione fisioterapica."
>
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-5">
      <nav aria-label="Percorso" class="text-sm text-ink/70">
        <a href="/" class="hover:text-coral-700">Home</a> / <span>Contatti</span>
      </nav>
      <h1 class="mt-4 font-display text-4xl font-semibold text-teal-900 md:text-6xl" data-reveal>
        Parliamone di persona
      </h1>

      <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_1.2fr]">
        <div class="space-y-6">
          <div class="rounded-3xl border border-teal-900/10 bg-white p-7 shadow-sm" data-reveal>
            <h2 class="font-display text-xl font-semibold text-teal-900">Dove siamo</h2>
            <address class="mt-2 not-italic text-ink/80">
              {STUDIO.indirizzo.via}, {STUDIO.indirizzo.cap} {STUDIO.indirizzo.citta} ({STUDIO.indirizzo.provincia})
            </address>
            <p class="mt-1 text-xs font-medium text-coral-700">Si riceve su appuntamento</p>
            <ul class="mt-3 space-y-1 text-sm text-ink/70">
              {STUDIO.orari.map(({ giorni, ore }) => (
                <li><span class="font-medium">{giorni}:</span> {ore}</li>
              ))}
            </ul>
            <h3 class="mt-5 text-sm font-semibold uppercase tracking-wider text-ink/70">Linee dirette</h3>
            <ul class="mt-2 space-y-1 text-sm text-ink/80">
              {STUDIO.contattiDiretti.map(({ nome, numero }) => (
                <li>
                  <span class="font-medium">{nome}:</span>{' '}
                  <a href={`tel:${numero.replace(/\s/g, '')}`} class="text-teal-700 hover:text-coral-700">{numero}</a>
                </li>
              ))}
            </ul>
            <div class="mt-5 flex flex-wrap gap-3">
              <a href={telHref} data-magnetic class="rounded-full bg-teal-700 px-5 py-2.5 text-sm font-semibold text-paper hover:bg-teal-900">
                📞 Chiama ora
              </a>
              <a href={waHref} rel="noopener" target="_blank" class="rounded-full bg-[#25D366] px-5 py-2.5 text-sm font-semibold text-white hover:brightness-95">
                WhatsApp
              </a>
            </div>
          </div>

          <div class="overflow-hidden rounded-3xl border border-teal-900/10 shadow-sm" data-reveal>
            <iframe
              title="Mappa: Studio Juvenilia, Via Giotto 28, Caserta"
              src={`https://www.openstreetmap.org/export/embed.html?bbox=${STUDIO.geo.lng - 0.006}%2C${STUDIO.geo.lat - 0.004}%2C${STUDIO.geo.lng + 0.006}%2C${STUDIO.geo.lat + 0.004}&layer=mapnik&marker=${STUDIO.geo.lat}%2C${STUDIO.geo.lng}`}
              class="h-72 w-full border-0"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <div class="space-y-8">
          <!-- Prenotazione WhatsApp-first -->
          <PrenotaWizard />

          <!-- Form contatto GDPR -->
          <div class="rounded-3xl border border-teal-900/10 bg-white p-7 shadow-sm" data-reveal>
            <h2 class="font-display text-xl font-semibold text-teal-900">Scrivici</h2>
            <form id="contact-form" class="mt-4 space-y-3" novalidate>
              <!-- honeypot anti-spam: invisibile agli umani, i bot lo compilano -->
              <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
              <input required name="nome" placeholder="Nome e cognome *" autocomplete="name" class="w-full rounded-xl border border-teal-900/20 px-4 py-2.5 text-sm" />
              <input required name="email" type="email" placeholder="Email *" autocomplete="email" class="w-full rounded-xl border border-teal-900/20 px-4 py-2.5 text-sm" />
              <textarea required name="messaggio" rows="4" placeholder="Come possiamo aiutarti? *" class="w-full rounded-xl border border-teal-900/20 px-4 py-2.5 text-sm"></textarea>
              <p class="text-xs leading-relaxed text-ink/70">
                Ti chiediamo di <strong>non inserire nel messaggio informazioni dettagliate sulla tua
                salute</strong>: ne parleremo di persona o al telefono.
              </p>
              <label class="flex items-start gap-2 text-xs text-ink/70">
                <input required type="checkbox" name="privacy" class="mt-0.5" />
                <span>
                  Ho letto l'<a href="/privacy" class="underline">informativa privacy</a> e acconsento al
                  trattamento dei dati per ricontattarmi. *
                </span>
              </label>
              <label class="flex items-start gap-2 text-xs text-ink/70">
                <input type="checkbox" name="salute" class="mt-0.5" />
                <span>
                  Se il messaggio contiene informazioni sul mio stato di salute, acconsento
                  esplicitamente al trattamento di tali dati (art. 9 GDPR).
                </span>
              </label>
              <button type="submit" class="rounded-full bg-teal-700 px-7 py-2.5 text-sm font-semibold text-paper hover:bg-teal-900">
                Invia il messaggio
              </button>
              <p id="contact-esito" class="hidden rounded-xl bg-teal-50 p-4 text-sm text-teal-900" role="status"></p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  /*
    Invio del form contatti via Web3Forms (https://web3forms.com):
    nessun backend proprio, il servizio inoltra il messaggio alla casella
    dello studio senza conservare i dati. La chiave è pubblica per design
    (vincolata alla casella di destinazione) e arriva da PUBLIC_WEB3FORMS_KEY.
  */
  const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY as string | undefined;

  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
  const esito = document.getElementById('contact-esito')!;

  function mostraEsito(testo: string, errore = false) {
    esito.classList.remove('hidden');
    esito.classList.toggle('bg-teal-50', !errore);
    esito.classList.toggle('text-teal-900', !errore);
    esito.classList.toggle('bg-coral-500/10', errore);
    esito.classList.toggle('text-coral-700', errore);
    esito.textContent = testo;
  }

  contactForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!contactForm.reportValidity()) return;

    if (!WEB3FORMS_KEY) {
      console.warn('PUBLIC_WEB3FORMS_KEY non configurata: impostala in .env o nelle variabili di build.');
      mostraEsito(
        'Il modulo non è al momento disponibile. Scrivici su WhatsApp o chiamaci: trovi i contatti qui accanto.',
        true,
      );
      return;
    }

    const dati = new FormData(contactForm);
    submitBtn.disabled = true;
    submitBtn.textContent = 'Invio in corso…';

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          access_key: WEB3FORMS_KEY,
          subject: 'Nuovo messaggio dal sito — Studio Juvenilia',
          from_name: 'Sito Studio Juvenilia',
          name: String(dati.get('nome')),
          email: String(dati.get('email')), // usato come reply-to
          message: String(dati.get('messaggio')),
          'Consenso privacy': dati.get('privacy') ? 'sì' : 'no',
          'Consenso dati salute (art. 9)': dati.get('salute') ? 'sì' : 'no',
          botcheck: dati.get('botcheck') ? 'on' : '',
        }),
      });
      const json = await res.json();
      if (!res.ok || !json.success) throw new Error(json.message ?? res.statusText);
      mostraEsito('✓ Messaggio inviato! Ti ricontatteremo il prima possibile negli orari di apertura.');
      contactForm.reset();
    } catch (err) {
      console.error('Invio form fallito:', err);
      mostraEsito(
        'Non siamo riusciti a inviare il messaggio. Riprova tra qualche minuto, oppure scrivici su WhatsApp o chiamaci.',
        true,
      );
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Invia il messaggio';
    }
  });
</script>
