---
import Base from '../layouts/Base.astro';

const tecnologie = [
  {
    nome: 'Dinamometro isocinetico',
    testo: 'Il cuore del Juvenilia Lab: misura la forza muscolare in ogni grado di movimento e permette un rinforzo sempre al massimo, in sicurezza. [PLACEHOLDER: modello esatto]',
    tag: 'Test e rinforzo',
  },
  {
    nome: 'Tecarterapia',
    testo: 'Diatermia capacitiva e resistiva per accelerare i processi riparativi di muscoli, tendini e articolazioni.',
    tag: 'Terapia strumentale',
  },
  {
    nome: 'Onde d’urto focali',
    testo: 'Trattamento mirato di tendinopatie croniche, calcificazioni e fasciti che non rispondono alle terapie tradizionali.',
    tag: 'Terapia strumentale',
  },
  {
    nome: 'Biofeedback',
    testo: 'Supporto strumentale per la riabilitazione del pavimento pelvico e il controllo motorio fine.',
    tag: 'Riabilitazione',
  },
];
---

<Base
  title="Tecnologie e macchinari | Studio Juvenilia Caserta"
  description="Le tecnologie dello Studio Juvenilia a Caserta: dinamometro isocinetico, tecarterapia, onde d'urto focali e biofeedback al servizio del tuo recupero."
>
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-5">
      <nav aria-label="Percorso" class="text-sm text-ink/50">
        <a href="/" class="hover:text-coral-600">Home</a> / <span>Tecnologie</span>
      </nav>
      <h1 class="mt-4 font-display text-4xl font-semibold text-teal-900 md:text-6xl" data-reveal>
        La tecnologia al servizio delle mani
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink/70" data-reveal>
        I macchinari non sostituiscono il ragionamento clinico: lo potenziano. Ecco gli strumenti
        con cui misuriamo, trattiamo e certifichiamo il tuo recupero.
      </p>

      <div class="mt-12 grid items-start gap-10 lg:grid-cols-2">
        <div>
          <div
            id="machine3d"
            class="relative aspect-square w-full rounded-3xl bg-gradient-to-b from-teal-50 to-teal-100 shadow-inner"
            role="img"
            aria-label="Modello 3D stilizzato del dinamometro isocinetico: trascina per ruotarlo"
          >
            <p class="pointer-events-none absolute bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-teal-900/80 px-4 py-1 text-xs text-paper">
              Trascina per ruotare il macchinario
            </p>
          </div>
          <p class="mt-3 text-xs text-ink/50">Modello 3D stilizzato del dinamometro isocinetico.</p>
        </div>

        <div class="space-y-5">
          {
            tecnologie.map((t, i) => (
              <article class="rounded-3xl border border-teal-900/10 bg-white p-7 shadow-sm" data-reveal data-reveal-delay={i * 0.06}>
                <span class="rounded-full bg-teal-50 px-3 py-1 text-xs font-semibold text-teal-700">{t.tag}</span>
                <h2 class="mt-3 font-display text-xl font-semibold text-teal-900">{t.nome}</h2>
                <p class="mt-2 text-sm leading-relaxed text-ink/70">{t.testo}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const el = document.getElementById('machine3d')!;
  const supportsWebGL = (() => {
    try {
      return !!document.createElement('canvas').getContext('webgl2');
    } catch {
      return false;
    }
  })();

  if (supportsWebGL) {
    const io = new IntersectionObserver(
      async ([entry]) => {
        if (!entry.isIntersecting) return;
        io.disconnect();
        const { mountMachine3D } = await import('../lib/machine3d');
        mountMachine3D(el);
      },
      { rootMargin: '200px' },
    );
    io.observe(el);
  }
</script>
