---
import Base from '../layouts/Base.astro';

const tecnologie = [
  {
    nome: 'Macchinario isocinetico',
    testo: 'Il cuore del Juvenilia Lab: test di prestazione muscolare, rinforzo con contrazioni isometriche e isotoniche, resistenza adattata alla forza espressa in ogni grado di movimento.',
    tag: 'Test e rinforzo',
  },
  {
    nome: 'Pedana baropodometrica',
    testo: 'Analisi elettronica della postura, del passo e del baricentro corporeo: l’appoggio plantare e l’equilibrio diventano dati misurabili.',
    tag: 'Valutazione',
  },
  {
    nome: 'Tecarterapia',
    testo: 'Diatermia capacitiva e resistiva per accelerare i processi riparativi di muscoli, tendini e articolazioni; usata anche a supporto del linfodrenaggio.',
    tag: 'Terapia strumentale',
  },
  {
    nome: 'Onde d’urto focali',
    testo: 'Onde acustiche ad alta energia per patologie muscolo-tendinee e ossee: stimolano la rigenerazione tissutale riducendo infiammazione e dolore.',
    tag: 'Terapia strumentale',
  },
  {
    nome: 'SISS — Campi magnetici pulsati focali',
    testo: 'Stimolazione dei tessuti muscolari superficiali e profondi con radiofrequenza: efficace sull’edema osseo e sul recupero muscolare.',
    tag: 'Terapia strumentale',
  },
  {
    nome: 'Biofeedback',
    testo: 'Supporto strumentale per la riabilitazione del pavimento pelvico e il controllo motorio fine.',
    tag: 'Riabilitazione',
  },
];
---

<Base
  title="Tecnologie e macchinari | Studio Juvenilia Caserta"
  description="Le tecnologie dello Studio Juvenilia a Caserta: dinamometro isocinetico, tecarterapia, onde d'urto focali e biofeedback al servizio del tuo recupero."
>
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-5">
      <nav aria-label="Percorso" class="text-sm text-ink/70">
        <a href="/" class="hover:text-coral-700">Home</a> / <span>Tecnologie</span>
      </nav>
      <h1 class="mt-4 font-display text-4xl font-semibold text-teal-900 md:text-6xl" data-reveal>
        La tecnologia al servizio delle mani
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink/70" data-reveal>
        I macchinari non sostituiscono il ragionamento clinico: lo potenziano. Ecco gli strumenti
        con cui misuriamo, trattiamo e certifichiamo il tuo recupero.
      </p>

      <div class="mt-12 grid items-start gap-10 lg:grid-cols-2">
        <div>
          <div
            id="machine3d"
            class="relative aspect-square w-full rounded-3xl bg-gradient-to-b from-teal-50 to-teal-100 shadow-inner"
            role="img"
            aria-label="Modello 3D stilizzato del dinamometro isocinetico: trascina per ruotarlo"
          >
            <p class="pointer-events-none absolute bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-teal-900/80 px-4 py-1 text-xs text-paper">
              Trascina per ruotare il macchinario
            </p>
          </div>
          <p class="mt-3 text-xs text-ink/70">Modello 3D stilizzato del dinamometro isocinetico.</p>
        </div>

        <div class="space-y-5">
          {
            tecnologie.map((t, i) => (
              <article class="rounded-3xl border border-teal-900/10 bg-white p-7 shadow-sm" data-reveal data-reveal-delay={i * 0.06}>
                <span class="rounded-full bg-teal-50 px-3 py-1 text-xs font-semibold text-teal-700">{t.tag}</span>
                <h2 class="mt-3 font-display text-xl font-semibold text-teal-900">{t.nome}</h2>
                <p class="mt-2 text-sm leading-relaxed text-ink/70">{t.testo}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const el = document.getElementById('machine3d')!;
  const supportsWebGL = (() => {
    try {
      return !!document.createElement('canvas').getContext('webgl2');
    } catch {
      return false;
    }
  })();

  // Fallback statico se WebGL manca o il caricamento del modulo 3D fallisce
  function fallbackSvg() {
    el.querySelector('p')?.remove();
    el.insertAdjacentHTML(
      'afterbegin',
      `<svg viewBox="0 0 400 400" class="h-full w-full" aria-hidden="true">
        <rect x="70" y="330" width="260" height="20" rx="10" fill="#123c40"/>
        <rect x="120" y="120" width="24" height="215" rx="10" fill="#1c5a5e"/>
        <circle cx="132" cy="100" r="34" fill="#123c40"/>
        <circle cx="132" cy="100" r="14" fill="#f2b95c"/>
        <rect x="126" y="130" width="14" height="110" rx="7" fill="#d95535" transform="rotate(-16 133 130)"/>
        <rect x="205" y="235" width="110" height="16" rx="8" fill="#1c5a5e"/>
        <rect x="295" y="150" width="16" height="100" rx="8" fill="#1c5a5e" transform="rotate(12 303 150)"/>
      </svg>`,
    );
  }

  if (supportsWebGL) {
    const io = new IntersectionObserver(
      async ([entry]) => {
        if (!entry.isIntersecting) return;
        io.disconnect();
        try {
          const { mountMachine3D } = await import('../lib/machine3d');
          mountMachine3D(el);
        } catch {
          fallbackSvg();
        }
      },
      { rootMargin: '200px' },
    );
    io.observe(el);
  } else {
    fallbackSvg();
  }
</script>
