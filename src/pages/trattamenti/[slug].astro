---
import Base from '../../layouts/Base.astro';
import { TRATTAMENTI } from '../../data/trattamenti';
import { TEAM } from '../../data/team';

export function getStaticPaths() {
  return TRATTAMENTI.map((t) => ({ params: { slug: t.slug }, props: { trattamento: t } }));
}

const { trattamento: t } = Astro.props;
const specialisti = TEAM.filter((p) => p.trattamenti.includes(t.slug));

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalTherapy',
    name: t.nome,
    description: t.metaDescription,
    provider: { '@id': new URL('/', Astro.site).href + '#clinic' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
      { '@type': 'ListItem', position: 2, name: 'Trattamenti', item: new URL('/trattamenti', Astro.site).href },
      { '@type': 'ListItem', position: 3, name: t.nome, item: new URL(`/trattamenti/${t.slug}`, Astro.site).href },
    ],
  },
  ...(t.faq.length
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: t.faq.map((f) => ({
            '@type': 'Question',
            name: f.domanda,
            acceptedAnswer: { '@type': 'Answer', text: f.risposta },
          })),
        },
      ]
    : []),
];
---

<Base title={t.metaTitle} description={t.metaDescription} schema={schema}>
  <article class="py-16">
    <div class="mx-auto max-w-4xl px-5">
      <nav aria-label="Percorso" class="text-sm text-ink/70">
        <a href="/" class="hover:text-coral-700">Home</a> /
        <a href="/trattamenti" class="hover:text-coral-700">Trattamenti</a> /
        <span>{t.nome}</span>
      </nav>

      <h1 class="mt-4 font-display text-4xl font-semibold text-teal-900 md:text-5xl" data-reveal>{t.nome}</h1>
      <p class="mt-3 text-xl text-coral-700" data-reveal>{t.sottotitolo}</p>

      {t.descrizione.map((p) => <p class="mt-5 leading-relaxed text-ink/80" data-reveal>{p}</p>)}

      <div class="mt-12 grid gap-8 md:grid-cols-2">
        <div class="rounded-3xl bg-teal-50 p-7" data-reveal>
          <h2 class="font-display text-xl font-semibold text-teal-900">Per chi è indicato</h2>
          <ul class="mt-4 space-y-2">
            {
              t.perChi.map((v) => (
                <li class="flex gap-2 text-sm text-ink/80">
                  <span class="text-coral-700" aria-hidden="true">✓</span>
                  {v}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="rounded-3xl bg-teal-50 p-7" data-reveal>
          <h2 class="font-display text-xl font-semibold text-teal-900">Come funziona</h2>
          <ol class="mt-4 space-y-2">
            {
              t.comeFunziona.map((v, i) => (
                <li class="flex gap-3 text-sm text-ink/80">
                  <span class="font-display font-semibold text-coral-700">{i + 1}.</span>
                  {v}
                </li>
              ))
            }
          </ol>
        </div>
      </div>

      {
        specialisti.length > 0 && (
          <section class="mt-12" aria-label="Professionisti di riferimento" data-reveal>
            <h2 class="font-display text-xl font-semibold text-teal-900">Chi se ne occupa</h2>
            <ul class="mt-4 flex flex-wrap gap-3">
              {specialisti.map((p) => (
                <li class="rounded-full border border-teal-300 bg-white px-4 py-2 text-sm">
                  <a href={`/chi-siamo#${p.slug}`} class="font-medium text-teal-900 hover:text-coral-700">
                    {p.nome}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        t.faq.length > 0 && (
          <section class="mt-12" aria-label="Domande frequenti" data-reveal>
            <h2 class="font-display text-2xl font-semibold text-teal-900">Domande frequenti</h2>
            <div class="mt-4 space-y-3">
              {t.faq.map((f) => (
                <details class="group rounded-2xl border border-teal-900/10 bg-white p-5">
                  <summary class="cursor-pointer font-medium text-teal-900 marker:content-none">
                    {f.domanda}
                    <span class="float-right text-coral-700 transition-transform group-open:rotate-45">+</span>
                  </summary>
                  <p class="mt-3 text-sm leading-relaxed text-ink/70">{f.risposta}</p>
                </details>
              ))}
            </div>
          </section>
        )
      }

      <div class="mt-14 rounded-3xl bg-coral-100 p-8 text-center" data-reveal>
        <h2 class="font-display text-2xl font-semibold text-teal-900">Pensi che faccia per te?</h2>
        <p class="mt-2 text-ink/70">Inizia con una valutazione: capiamo insieme se e come possiamo aiutarti.</p>
        <a href="/contatti#prenota" data-magnetic class="mt-6 inline-block rounded-full bg-coral-500 px-8 py-3 font-semibold text-white hover:bg-coral-600">
          Prenota una valutazione
        </a>
      </div>
    </div>
  </article>
</Base>
